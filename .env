# ── Copy to .env and fill in values ──────────────────────────────────────────

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Pin a specific model tag to avoid surprises across restarts:
OLLAMA_MODEL=mistral-nemo:12b-instruct-2407-q3_K_M
OLLAMA_TIMEOUT=5
OLLAMA_STARTUP_WAIT=15
OLLAMA_GEN_TIMEOUT=30

# ChromaDB
CHROMA_PATH=./chromadb_store

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Auto-classification
# Confidence threshold below which the user is shown an override prompt:
CLASSIFIER_CONFIDENCE=0.55
CLASSIFIER_RAG_RESULTS=10

# Paths
PATENT_TYPES_JSON=patent_types.json
PROJECTS_DIR=./projects
TEMP_DIR=./temp

# CrewAI crew timeout (seconds)
CREW_TIMEOUT_SECONDS=300

# ── Mistral API (for quality benchmarking) ────────────────────────────────────
# Set USE_MISTRAL_API=true to route all LLM calls through Mistral API.
# ⚠ Set back to false before processing real patent documents.
USE_MISTRAL_API=false
MISTRAL_API_KEY=59oBQc8JeAWgdx4NuiKftl5UxgF9V7ZG
MISTRAL_ORCHESTRATOR_MODEL=mistral-large-latest
