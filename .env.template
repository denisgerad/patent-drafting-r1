# ═══════════════════════════════════════════════════════════════════════════
# Patent RAG — Environment Configuration
# Copy this file to .env and fill in values for your chosen provider.
# ═══════════════════════════════════════════════════════════════════════════

# Choose ONE: ollama | azure | claude | openai
LLM_PROVIDER=ollama


# ─── OPTION 1: Local Ollama (default, no API key) ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
OLLAMA_TIMEOUT=5
OLLAMA_STARTUP_WAIT=15
OLLAMA_GEN_TIMEOUT=30


# ─── OPTION 2: Azure OpenAI ────────────────────────────────────────────────
# LLM_PROVIDER=azure
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-patent
AZURE_OPENAI_API_VERSION=2024-02-01


# ─── OPTION 3: Anthropic Claude ────────────────────────────────────────────
# LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
# Options: claude-opus-4-20250514 | claude-sonnet-4-20250514 | claude-haiku-4-5-20251001


# ─── OPTION 4: OpenAI Direct ───────────────────────────────────────────────
# LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o


# ─── EPO OPS (for reference patent gap analysis) ─────────────────────────
EPO_CLIENT_ID=your_epo_client_id_here
EPO_CLIENT_SECRET=your_epo_client_secret_here

# ─── Hybrid augmentation ──────────────────────────────────────────────────
# Phase 2 cloud augmentation — set to 'true' to enable.
# Only category labels are sent to Claude, never patent content.
# Requires ANTHROPIC_API_KEY to be set.
ENABLE_CLOUD_AUGMENTATION=false

# ─── Shared settings (same for all providers) ──────────────────────────────
CHROMA_PATH=./chromadb_store
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CLASSIFIER_CONFIDENCE=0.55
CLASSIFIER_RAG_RESULTS=10
PATENT_TYPES_JSON=patent_types.json
PROJECTS_DIR=./projects
TEMP_DIR=./temp
CREW_TIMEOUT_SECONDS=300
